<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/login_title"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/dialogEmailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:autofillHints="emailAddress"
        android:background="@drawable/input_field_bg"
        android:drawableStart="@drawable/ic_lucide_mail"
        android:drawablePadding="12dp"
        android:drawableTint="#9E9E9E"
        android:hint="@string/email_hint"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#9E9E9E" />

    <EditText
        android:id="@+id/dialogPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:autofillHints="password"
        android:background="@drawable/input_field_bg"
        android:drawableStart="@drawable/ic_lucide_lock"
        android:drawablePadding="12dp"
        android:drawableTint="#9E9E9E"
        android:hint="@string/password_hint"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#9E9E9E" />

    <EditText
        android:id="@+id/dialogServerUrlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/input_field_bg"
        android:drawableStart="@drawable/ic_link_24dp"
        android:drawablePadding="12dp"
        android:drawableTint="#9E9E9E"
        android:hint="@string/server_url_hint"
        android:inputType="textUri"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#9E9E9E" />

</LinearLayout>
