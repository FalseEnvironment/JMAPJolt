<?xml version="1.0" encoding="utf-8"?>
<!-- Email list item entrance: slides up from 20dp with fade -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/md3_emphasized">
    <translate
        android:fromYDelta="16%"
        android:toYDelta="0%"
        android:duration="280" />
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="280" />
</set>
