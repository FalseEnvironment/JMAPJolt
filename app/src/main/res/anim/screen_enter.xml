<?xml version="1.0" encoding="utf-8"?>
<!-- Forward navigation: new screen enters from the right -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/md3_emphasized">
    <translate
        android:fromXDelta="8%"
        android:toXDelta="0%"
        android:duration="300" />
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="300" />
</set>
