<?xml version="1.0" encoding="utf-8"?>
<!-- Back navigation: current screen exits to the right -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/md3_emphasized_decelerate">
    <translate
        android:fromXDelta="0%"
        android:toXDelta="6%"
        android:duration="200" />
    <alpha
        android:fromAlpha="1.0"
        android:toAlpha="0.0"
        android:duration="200" />
</set>
